# Supabase — used by app/api/webhooks/trello/route.ts and the cockpit reads
# Find these in your Supabase project: Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service-role key: bypasses Row Level Security. SERVER-SIDE ONLY.
# Never expose this in client code or commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — used for any assistant-backed features.
ANTHROPIC_API_KEY=your-anthropic-key

# Gmail — the inbox cold-email / candidate mail is sent FROM (app/api/outbound/send,
# app/api/.../send-email). Use a Google App Password (16 chars), not the login pw.
GMAIL_USER=you@yourdomain.com
GMAIL_PASSWORD=your-16-char-app-password

# Outbound cold-email send switch. UNSET/false = DRY RUN: every message is
# rendered and previewed but NOTHING is sent and no one is marked contacted.
# Set to exactly "true" to ARM real sends from GMAIL_USER (see the OUTBOUND_LIVE_SEND
# gate in app/api/outbound/send/route.ts). Keep this in the Vercel project env.
OUTBOUND_LIVE_SEND=false
